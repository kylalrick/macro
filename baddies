-- Loading Logic (30 Seconds)
local duration = 30 
local elapsed = 0
local connection
connection = RunService.RenderStepped:Connect(function(delta)
    elapsed += delta
    local progress = math.min(elapsed / duration, 1)
    Bar.Size = UDim2.new(progress, 0, 1, 0)
    PercentageText.Text = string.format("%.0f%%", progress * 100)
    
    if progress >= 1 then
        connection:Disconnect()
        task.wait(0.5)
        LoadingGui:Destroy()
        startMacro()
    end
end)

-- --- UNLIMITED MACRO GUI ---
function startMacro()
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "TGM_Unlimited"
    ScreenGui.Parent = player:WaitForChild("PlayerGui")

    local Main = Instance.new("Frame")
    Main.Size = UDim2.new(0, 180, 0, 260) -- Small & Compact for Mobile
    Main.Position = UDim2.new(0.5, -90, 0.4, -130)
    Main.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    Main.BorderSizePixel = 2
    Main.Active = true
    Main.Draggable = true
    Main.Parent = ScreenGui

    local TitleLabel = Instance.new("TextLabel")
    TitleLabel.Size = UDim2.new(1, 0, 0, 25)
    TitleLabel.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    TitleLabel.Text = "TGM UNLIMITED"
    TitleLabel.TextColor3 = Color3.new(1, 1, 1)
    TitleLabel.TextSize = 12
    TitleLabel.Font = Enum.Font.Code
    TitleLabel.Parent = Main

    local ActionList = Instance.new("ScrollingFrame")
    ActionList.Size = UDim2.new(0.9, 0, 0, 90)
    ActionList.Position = UDim2.new(0.05, 0, 0.15, 0)
    ActionList.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    ActionList.CanvasSize = UDim2.new(0, 0, 0, 0)
    ActionList.ScrollBarThickness = 2
    ActionList.Parent = Main
    local UIList = Instance.new("UIListLayout")
    UIList.Parent = ActionList

    local ACTIONS = {}

    local function AddToUI(text)
        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(1, 0, 0, 18)
        lbl.BackgroundTransparency = 1
        lbl.Text = " > " .. text
        lbl.TextColor3 = Color3.new(1, 1, 1)
        lbl.TextSize = 10
        lbl.Font = Enum.Font.Code
        lbl.Parent = ActionList
        ActionList.CanvasSize = UDim2.new(0, 0, 0, UIList.AbsoluteContentSize.Y)
    end

    local InputBox = Instance.new("TextBox")
    InputBox.Size = UDim2.new(0.9, 0, 0, 25)
    InputBox.Position = UDim2.new(0.05, 0, 0.52, 0)
    InputBox.PlaceholderText = "Key or Seconds..."
    InputBox.Text = ""
    InputBox.TextSize = 10
    InputBox.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    InputBox.TextColor3 = Color3.new(1,1,1)
    InputBox.Parent = Main

    local AddAction = Instance.new("TextButton")
    AddAction.Size = UDim2.new(0.43, 0, 0, 25)
    AddAction.Position = UDim2.new(0.05, 0, 0.65, 0)
    AddAction.Text = "+ Action"
    AddAction.TextSize = 10
    AddAction.Parent = Main

    local AddWait = Instance.new("TextButton")
    AddWait.Size = UDim2.new(0.43, 0, 0, 25)
    AddWait.Position = UDim2.new(0.52, 0, 0.65, 0)
    AddWait.Text = "+ Wait"
    AddWait.TextSize = 10
    AddWait.Parent = Main

    local ClearBtn = Instance.new("TextButton")
    ClearBtn.Size = UDim2.new(0.9, 0, 0, 20)
    ClearBtn.Position = UDim2.new(0.05, 0, 0.76, 0)
    ClearBtn.Text = "Clear List"
    ClearBtn.TextSize = 10
    ClearBtn.Parent = Main

    local RunBtn = Instance.new("TextButton")
    RunBtn.Size = UDim2.new(0.9, 0, 0, 30)
    RunBtn.Position = UDim2.new(0.05, 0, 0.86, 0)
    RunBtn.BackgroundColor3 = Color3.fromRGB(80, 0, 200)
    RunBtn.Text = "START"
    RunBtn.TextColor3 = Color3.new(1, 1, 1)
    RunBtn.Font = Enum.Font.Code
    RunBtn.Parent = Main

    -- LOGIC
    AddAction.MouseButton1Click:Connect(function()
        local val = InputBox.Text ~= "" and InputBox.Text or "e"
        table.insert(ACTIONS, {Type = "Key", Value = val})
        AddToUI("Press: " .. val)
    end)

    AddWait.MouseButton1Click:Connect(function()
        local val = tonumber(InputBox.Text) or 0.1
        table.insert(ACTIONS, {Type = "Wait", Value = val})
        AddToUI("Wait: " .. val .. "s")
    end)

    ClearBtn.MouseButton1Click:Connect(function()
        ACTIONS = {}
        for _, v in pairs(ActionList:GetChildren()) do if v:IsA("TextLabel") then v:Destroy() end end
    end)

    local running = false
    RunBtn.MouseButton1Click:Connect(function()
        running = not running
        RunBtn.Text = running and "STOP" or "START"
        RunBtn.BackgroundColor3 = running and Color3.fromRGB(200, 0, 0) or Color3.fromRGB(80, 0, 200)
        
        if running then
            task.spawn(function()
                local vim = game:GetService("VirtualInputManager")
                while running do
                    for _, act in pairs(ACTIONS) do
                        if not running then break end
                        if act.Type == "Key" then
                            vim:SendKeyEvent(true, act.Value, false, game)
                            task.wait(0.01)
                            vim:SendKeyEvent(false, act.Value, false, game)
                        else
                            task.wait(act.Value)
                        end
                    end
                    task.wait(0.01)
                end
            end)
        end
    end)
end
